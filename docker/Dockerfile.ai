# syntax=docker/dockerfile:1
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-gi python3-gi-cairo gir1.2-gstreamer-1.0 \
    gstreamer1.0-tools gstreamer1.0-plugins-base gstreamer1.0-plugins-good \
    gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav \
    libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 \
    yt-dlp ffmpeg curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Malý MP4 v image (mimo /data/samples — bind mount by ho jinak přepsal prázdnou složkou)
RUN mkdir -p /opt/rpy/assets \
    && curl -fsSL -o /opt/rpy/assets/sample.mp4 \
      "https://storage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4"

WORKDIR /app

COPY pyproject.toml /app/
COPY shared /app/shared
COPY services /app/services
COPY config /app/config

RUN pip install --no-cache-dir --break-system-packages -e .

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV ENVIRONMENT=production

EXPOSE 8081

CMD ["python3", "-m", "services.ai_core"]
