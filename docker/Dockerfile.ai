# syntax=docker/dockerfile:1
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-gi python3-gi-cairo gir1.2-gstreamer-1.0 \
    gstreamer1.0-tools gstreamer1.0-plugins-base gstreamer1.0-plugins-good \
    gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav \
    libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 \
    yt-dlp ffmpeg curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Malý MP4 v image — více zrcadel (Google gtv bucket umí vracet 403 mimo prohlížeč / při buildu).
RUN mkdir -p /opt/rpy/assets \
    && ( curl -fsSL --retry 3 -L -o /opt/rpy/assets/sample.mp4 \
           "https://samplelib.com/lib/preview/mp4/sample-5s.mp4" \
       || curl -fsSL --retry 3 -L -o /opt/rpy/assets/sample.mp4 \
           "https://filesamples.com/samples/video/mp4/sample_640x360.mp4" \
       || curl -fsSL --retry 3 -L -o /opt/rpy/assets/sample.mp4 \
           "https://storage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4" ) \
    && test "$(wc -c < /opt/rpy/assets/sample.mp4)" -ge 4096 \
    && ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of default=nw=1:nk=1 /opt/rpy/assets/sample.mp4 | grep -q .

WORKDIR /app

COPY pyproject.toml /app/
COPY shared /app/shared
COPY services /app/services
COPY config /app/config

RUN pip install --no-cache-dir --break-system-packages -e .

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV ENVIRONMENT=production

EXPOSE 8081

CMD ["python3", "-m", "services.ai_core"]
