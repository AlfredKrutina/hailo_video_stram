# Kopírujte do `.env` vedle `docker/docker-compose.yml` nebo exportujte před `docker compose`.
# Viz také docs/DEPLOYMENT_SMOKE.md (:80 nginx vs :8080 web).

# --- Sdílené ---
ENVIRONMENT=staging

# --- Postgres (web + ai_core) ---
POSTGRES_USER=rpy
POSTGRES_PASSWORD=rpy
POSTGRES_DB=rpy
DATABASE_URL=postgresql+psycopg://rpy:rpy@postgres:5432/rpy

# --- ai_core: zdroj videa ---
SOURCE_URI=file:///opt/rpy/assets/sample.mp4
RPY_RTSP_FORCE_TCP=1
RPY_RTSP_LATENCY_MS=300

# --- ai_core: inference ---
USE_HAILO=1
# RPY_INFER_BACKEND=onnx
# RPY_ONNX_MODEL_PATH=/models/yolov8n.onnx
# RPY_HAILO_HEF_STAGE1=/models/yolov8m_h10.hef
# RPY_HAILO_GST_BIN_DESCRIPTION='queue ! videoconvert ! ...'

# --- Zařízení Hailo (host path → kontejner; výchozí /dev/hailo0) ---
RPY_HAILO_DEVICE=/dev/hailo0
# Volitelný sysfs reset PCI (RPi / PC s Hailo PCI):
# RPY_HAILO_PCI_RESET_PATH=/sys/bus/pci/devices/0000:01:00.0/reset

# ONNX image build (docker build arg):
# INSTALL_ONNX=1

# --- web: bridge na video WS ai_core (vnitřní síť Docker; port 8081 neexportovat na hosta bez nutnosti) ---
RPY_AI_CORE_VIDEO_WS_URL=ws://ai_core:8081/ws/video

# --- Volitelné buildy ---
# INSTALL_ONNX=0
